# Bot Trade Arena — Environment Configuration
# Copy to .env and fill in your values

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/bot_trade_arena?schema=public"
REDIS_URL="redis://localhost:6379"

# ============================================================
# AUTH
# ============================================================
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================================
# SERVER
# ============================================================
PORT=8080
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# ============================================================
# MARKET DATA
# ============================================================
# Using Binance WebSocket (free, no API key needed for public data)
MARKET_DATA_PROVIDER="binance"
BINANCE_WS_URL="wss://stream.binance.com:9443/ws"

# Default trading symbols
DEFAULT_SYMBOLS="btcusdt,ethusdt,solusdt,bnbusdt,xrpusdt,dogeusdt"

# ============================================================
# MATCH ENGINE
# ============================================================
DEFAULT_MATCH_DURATION=300        # 5 minutes
DEFAULT_STARTING_CAPITAL=100000   # $100k virtual
MAX_OPEN_POSITIONS=5
MAX_POSITION_PCT=0.3              # 30% of capital per position
MIN_TRADE_INTERVAL=3              # 3 seconds between trades
SNAPSHOT_INTERVAL=5               # Snapshot every 5 seconds for replays

# ============================================================
# BILLING (Stripe)
# ============================================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_COMPETITOR="price_..."
STRIPE_PRICE_PRO="price_..."

# ============================================================
# RATE LIMITS
# ============================================================
API_RATE_LIMIT_WINDOW=60000       # 1 minute
API_RATE_LIMIT_MAX_FREE=30        # 30 requests/min for free users
API_RATE_LIMIT_MAX_PAID=120       # 120 requests/min for paid users

# ============================================================
# SEASONS
# ============================================================
SEASON_DURATION_DAYS=90           # 3-month seasons
